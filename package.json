{
  "name": "cactus-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx src/harness/simulate.ts",
    "server": "tsx src/server/index.ts",
    "server:watch": "tsx watch src/server/index.ts",
    "client:install": "npm install --prefix client",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "desktop:install": "npm install --prefix desktop",
    "desktop:dev": "concurrently -k -n server,client,desktop -c blue,green,magenta \"npm run server:watch\" \"npm run client:dev\" \"npm run dev --prefix desktop\"",
    "desktop:package": "npm run package --prefix desktop",
    "desktop:make": "npm run make --prefix desktop",
    "desktop:test": "npm run test --prefix desktop",
    "desktop:smoke": "npm run smoke --prefix desktop",
    "desktop:smoke:packaged": "npm run smoke:packaged --prefix desktop",
    "dev": "concurrently -k -n server,client -c blue,green \"npm run server:watch\" \"npm run client:dev\""
  },
  "devDependencies": {
    "@colyseus/testing": "^0.16.3",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@colyseus/tools": "^0.16.20",
    "colyseus": "^0.16.5",
    "express": "^4.22.2"
  }
}
